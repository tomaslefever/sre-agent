# API Keys
OPENAI_API_KEY=sk-proj-your-key-here

# Observability (Arize Phoenix)
# Local: http://localhost:6006/v1/traces
# Docker Stack: http://phoenix:6006/v1/traces
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces

# Relational Database (PostgreSQL)
# Format: postgresql://user:password@host:port/db_name
DATABASE_URL=postgresql://agentx:supersecret@postgres:5432/chat_history

# Vector Database (Qdrant)
# Local: http://localhost:6333
# Docker Stack: http://qdrant-db:6333
QDRANT_URL=http://qdrant-db:6333

# GitHub (for creating branches and automatic PRs)
# Token needs 'repo' scope (Full control of private repositories)
GITHUB_TOKEN=ghp_your-token-here

# OpenAI Model (default: gpt-4o)
OPENAI_MODEL=gpt-4o
